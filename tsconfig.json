{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": { "@/*": ["src/*"] },
    "types": ["vite/client"],
    "noEmit": true
  },
  "include": ["src", "vite.config.ts", "env.d.ts"],
  "exclude": ["node_modules", "dist"]
}
