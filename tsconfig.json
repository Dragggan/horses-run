{
  "compilerOptions": {
    "target": "ES2022",      // Must be >= ES2015 for private fields
    "module": "ESNext",      // Required for Vite ESM modules
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "allowJs": true,
    "strict": true,
    "skipLibCheck": true,    // skips node_modules TS errors
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
